// ─── .aichat on/off ───────────────────────────────────────────────────────────
export const aichatCommand = {
  name: 'aichat',
  execute: async ({ sock, msg, args, isOwner, isAdmin, phoneNumber }) => {
    if (!isOwner && !isAdmin) throw new Error('This command requires admin or owner privileges.');
    const jid     = msg.key.remoteJid;
    const isGroup = jid.endsWith('@g.us');
    const action  = args[0]?.toLowerCase();

    if (action === 'on') {
      // Enable globally (works in all chats) AND per current chat
      updateChatSettings(phoneNumber, jid, { automation: { aichat: { enabled: true } } });
      const note = isGroup
        ? ' In groups, I reply when mentioned or replied to.'
        : ' I will respond to all messages in this chat.';
      return await sock.sendMessage(jid, {
        text: `✅ *AI Chatbot* is now *ON*.${note}\n\n🤖 _Powered by GPT-5 | ZENTRIX MD BY ZENTRIX TECH_\n⚡ _Forged by UNKNOWN DEV_`
      }, { quoted: msg });
    }

    if (action === 'off') {
      updateChatSettings(phoneNumber, jid, { automation: { aichat: { enabled: false } } });
      return await sock.sendMessage(jid, { text: '❌ *AI Chatbot* is now *OFF* for this chat.' }, { quoted: msg });
    }

    // Status
    const s      = getChatSettings(phoneNumber, jid);
    const status = s.automation?.aichat?.enabled ? '🟢 ON' : '🔴 OFF';
    const vmOn   = s.automation?.voicemode?.enabled ? '🟢 ON' : '🔴 OFF';
    const vmLang = s.automation?.voicemode?.lang || 'en';
    const info   = isGroup
      ? '\n📌 _Groups: replies when mentioned or replied to._'
      : '\n📌 _DMs: replies to every message._';
    await sock.sendMessage(jid, {
      text: `ℹ️ *AI Chat Status:* ${status}${info}\n🎙️ *Voice Mode:* ${vmOn} _(lang: ${vmLang})_\n\n*Commands:*\n• .aichat on/off\n• .chatbot on/off\n• .voicemode english\n• .voicemode off\n\n_ZENTRIX MD BY ZENTRIX TECH | Forged by UNKNOWN DEV_`
    }, { quoted: msg });
  }
};

export const chatbotCommand = {
  name: 'chatbot',
  aliases: ['cb'],
  execute: async ({ sock, msg, args, isOwner, isAdmin, phoneNumber }) => {
    if (!isOwner && !isAdmin) throw new Error('This command requires admin or owner privileges.');
    const jid     = msg.key.remoteJid;
    const isGroup = jid.endsWith('@g.us');
    const action  = args[0]?.toLowerCase();

    if (action === 'on') {
      updateChatSettings(phoneNumber, jid, { automation: { aichat: { enabled: true } } });
      const note = isGroup
        ? ' In groups, tag me or reply to me to chat.'
        : ' I will reply to every message in this chat.';
      return await sock.sendMessage(jid, {
        text: `🤖 *Chatbot* is now *ON*.${note}\n\n_Powered by ZENTRIX MD AI_`
      }, { quoted: msg });
    }

    if (action === 'off') {
      updateChatSettings(phoneNumber, jid, { automation: { aichat: { enabled: false } } });
      return await sock.sendMessage(jid, {
        text: '❌ *Chatbot* is now *OFF* for this chat.'
      }, { quoted: msg });
    }

    // Status
    const s      = getChatSettings(phoneNumber, jid);
    const status = s.automation?.aichat?.enabled ? '🟢 ON' : '🔴 OFF';
    await sock.sendMessage(jid, {
      text: `ℹ️ *Chatbot Status:* ${status}\n\nUsage: *.chatbot on/off*\n${isGroup ? '_Groups: mention or reply to me._' : '_DMs: replies to every message._'}`
    }, { quoted: msg });
  }
};

// ─── .voicemode <language|off> ────────────────────────────────────────────────
export const voicemodeCommand = {
  name: 'voicemode',
  execute: async ({ sock, msg, args, isOwner, isAdmin, phoneNumber }) => {
    if (!isOwner && !isAdmin) throw new Error('This command requires admin or owner privileges.');
    const jid   = msg.key.remoteJid;
    const input = args[0]?.toLowerCase();

    // Show language list
    if (!input) {
      const langList = Object.entries(TTS_LANGUAGES)
        .map(([name, code]) => `• *${name}* (${code})`)
        .join('\n');
      return await sock.sendMessage(jid, {
        text: `🎙️ *Voice Mode — Supported Languages:*\n\n${langList}\n\n*Usage:*\n• .voicemode english\n• .voicemode arabic\n• .voicemode off\n\n_ZENTRIX MD BY ZENTRIX TECH | Forged by UNKNOWN DEV_`
      });
    }

    // Turn off
    if (input === 'off' || input === 'disable') {
      updateChatSettings(phoneNumber, jid, { automation: { voicemode: { enabled: false, lang: 'en' } } });
      return await sock.sendMessage(jid, {
        text: '🔇 *Voice Mode* is now *OFF*. AI will reply in text only.'
      });
    }

    // Match language name
    const langCode = TTS_LANGUAGES[input];
    if (!langCode) {
      const similar = Object.keys(TTS_LANGUAGES)
        .filter(l => l.startsWith(input[0]))
        .slice(0, 6)
        .join(', ');
      return await sock.sendMessage(jid, {
        text: `❌ Unknown language: *${input}*${similar ? `\n\nSimilar: ${similar}` : ''}\n\nType *.voicemode* to see all supported languages.`
      });
    }

    // Save setting
    updateChatSettings(phoneNumber, jid, {
      automation: { voicemode: { enabled: true, lang: langCode } }
    });

    const langDisplay = input.charAt(0).toUpperCase() + input.slice(1);

    await sock.sendMessage(jid, {
      text: `✅ *Voice Mode* activated!\n🌐 Language: *${langDisplay}* (${langCode})\n\n🎙️ AI will now send both text + voice note replies.\n\n_ZENTRIX MD BY ZENTRIX TECH | Forged by UNKNOWN DEV_`
    });

    // Demo voice note in the selected language
    await sock.sendMessage(jid, { react: { text: '🎙️', key: msg.key } });
    const demoText = `Hello! Voice mode is now active in ${langDisplay}. I am ZENTRIX MD AI, forged by UNKNOWN DEV.`;
    const oggBuf   = await textToVoiceNote(demoText, langCode);
    if (oggBuf) {
      await sendVoiceNote(sock, jid, oggBuf, msg);
    }
  }
};

// ─── .flux / .fluxpro / .flux2 ───────────────────────────────────────────────
export const fluxCommand = {
  name: 'flux',
  description: 'Generate high-quality images using Flux Pro 2 AI.',
  usage: '.flux <prompt>',
  category: 'ai image generation',
  subCategory: 'image',
  roleRequired: 'user',
  groupOnly: false,
  emoji: '🎨',
  execute: async ({ sock, msg, args }) => {
    const jid    = msg.key.remoteJid;
    const prompt = args.join(' ').trim();
    const react  = (emoji) => sock.sendMessage(jid, { react: { text: emoji, key: msg.key } });

    if (!prompt) {
      await sock.sendMessage(jid, {
        text: `⚠️ *Usage:* .flux <prompt>\n\n*Example:* .flux a futuristic neon city at night`
      }, { quoted: msg });
      return;
    }

    await react('🎨');

    try {
      // Step 1 — Kick off generation
      const { data: initRes } = await axios.get(
        `https://omegatech-api.dixonomega.tech/api/ai/flux-pro2?prompt=${encodeURIComponent(prompt)}`,
        { timeout: 15000 }
      );

      if (!initRes?.success || !initRes?.task_id) {
        throw new Error('Failed to start generation task.');
      }

      const taskId = initRes.task_id;
      let resultUrl = null;

      // Step 2 — Poll every 2s (fast) up to 30 attempts (60s max)
      for (let i = 0; i < 30; i++) {
        await new Promise(r => setTimeout(r, 2000));
        const { data: check } = await axios.get(
          `https://omegatech-api.dixonomega.tech/api/ai/nano-banana2-result?task_id=${taskId}`,
          { timeout: 10000 }
        );
        if (check?.status === 'completed' && check?.image_url) {
          resultUrl = check.image_url;
          break;
        }
        if (check?.status === 'failed') throw new Error('Generation failed on the server.');
      }

      if (!resultUrl) throw new Error('Generation timed out after 60 seconds.');

      // Step 3 — Send image and react done simultaneously
      await Promise.all([
        sock.sendMessage(jid, {
          image: { url: resultUrl },
          caption: `✨ *FLUX PRO 2*\n\n📝 *Prompt:* ${prompt}\n\n_ZENTRIX MD BY ZENTRIX TECH | Powered by Omegatech API_`,
          contextInfo: {
            forwardedNewsletterMessageInfo: {
              newsletterJid: '120363425412882254@newsletter',
              newsletterName: '𝐙𝐄𝐍𝐓𝐑𝐈𝐗 𝐓𝐄𝐂𝐇 𓅯',
              serverMessageId: -1,
            },
          },
        }, { quoted: msg }),
        react('✅'),
      ]);

    } catch (e) {
      await react('❌');
      await sock.sendMessage(jid, { text: `❌ *Error:* ${e.message}` }, { quoted: msg });
    }
  },
};

// Aliases
export const fluxproCommand  = { ...fluxCommand, name: 'fluxpro'  };
export const fluxpro2Command = { ...fluxCommand, name: 'fluxpro2' };
export const flux2Command    = { ...fluxCommand, name: 'flux2'    };
