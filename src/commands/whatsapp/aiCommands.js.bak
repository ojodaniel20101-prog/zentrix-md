const __filename  = fileURLToPath(import.meta.url);
const __dirname   = path.dirname(__filename);
const execFileAsync = promisify(execFile);

const API_BASE = 'https://apis.prexzyvilla.site';

// ─── TTS Language Map (display name → endpoint suffix) ────────────────────────
export const TTS_LANGUAGES = {
  english:    'en',
  indonesian: 'id',
  spanish:    'es',
  french:     'fr',
  german:     'de',
  italian:    'it',
  portuguese: 'pt',
  dutch:      'nl',
  polish:     'pl',
  russian:    'ru',
  japanese:   'ja',
  korean:     'ko',
  chinese:    'zhcn',
  taiwanese:  'zhtw',
  arabic:     'ar',
  hindi:      'hi',
  thai:       'th',
  vietnamese: 'vi',
  turkish:    'tr',
  swedish:    'sv',
  norwegian:  'no',
  danish:     'da',
  finnish:    'fi',
  greek:      'el',
  hebrew:     'he',
  czech:      'cs',
  hungarian:  'hu',
  romanian:   'ro',
  ukrainian:  'uk',
};

// ─── Ensure tmp dir exists ────────────────────────────────────────────────────
function getTmpDir() {
  const dir = path.join(__dirname, '../../../tmp/media');
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
  return dir;
}

// ─── TTS → OGG Opus (WhatsApp PTT compatible) ────────────────────────────────
async function textToVoiceNote(text, langSuffix = 'en') {
  const tmpDir  = getTmpDir();
  const id      = `tts_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`;
  const rawFile = path.join(tmpDir, `${id}_raw`);   // unknown format from API
  const oggFile = path.join(tmpDir, `${id}.ogg`);

  try {
    // 1. Fetch TTS audio from API
    const url = `${API_BASE}/tts/tts-${langSuffix}?text=${encodeURIComponent(text)}`;
    const res = await axios.get(url, { responseType: 'arraybuffer', timeout: 25000 });
    const buf = Buffer.from(res.data);

    if (buf.byteLength < 500) {
      logger.warn(`[TTS] Response too small (${buf.byteLength} bytes) — likely an error`);
      return null;
    }

    // 2. Save raw bytes (could be mp3, wav, etc.)
    fs.writeFileSync(rawFile, buf);

    // 3. Convert to OGG Opus with ffmpeg (required by WhatsApp for PTT)
    await execFileAsync('ffmpeg', [
      '-y',                    // overwrite
      '-i', rawFile,           // input (auto-detect format)
      '-c:a', 'libopus',       // Opus codec — required for WA voice notes
      '-b:a', '64k',           // 64kbps — clear enough, small enough
      '-vbr', 'on',
      '-ar', '48000',          // 48kHz sample rate (Opus standard)
      '-ac', '1',              // mono
      oggFile
    ]);

    // 4. Read converted file
    const oggBuf = fs.readFileSync(oggFile);
    return oggBuf;

  } catch (err) {
    logger.error(`[TTS] Voice note conversion failed: ${err.message}`);
    return null;
  } finally {
    // Clean up temp files
    try { if (fs.existsSync(rawFile)) fs.unlinkSync(rawFile); } catch (_) {}
    try { if (fs.existsSync(oggFile)) fs.unlinkSync(oggFile); } catch (_) {}
  }
}

// ─── Send WhatsApp Voice Note (PTT) ──────────────────────────────────────────
async function sendVoiceNote(sock, chatId, oggBuffer, quotedMsg) {
  await sock.sendMessage(
    chatId,
    {
      audio:    oggBuffer,
      mimetype: 'audio/ogg; codecs=opus',  // exact mimetype WhatsApp expects
      ptt:      true,                       // marks it as a voice note
    },
    { quoted: quotedMsg }
  );
}

// ─── Core AI Call — prexzyvilla (with fallback endpoints) ────────────────────
const API_BASE_AI = 'https://apis.prexzyvilla.site';
async function callGPT5(prompt) {
  const endpoints = [
    `${API_BASE_AI}/ai/gpt-5?text=`,
    `${API_BASE_AI}/ai/gpt4?text=`,
    `${API_BASE_AI}/ai/chatbot?text=`,
  ];

  for (const endpoint of endpoints) {
    try {
      const { data } = await axios.get(endpoint + encodeURIComponent(prompt), { timeout: 30000 });
      const text =
        data?.text ||
        data?.result ||
        data?.response ||
        data?.data?.response ||
        data?.message ||
        (typeof data === 'string' ? data : null);
      if (text && text.trim()) return text.trim();
    } catch (err) {
      logger.warn(`[AI] Endpoint failed: ${endpoint} — ${err.message}`);
    }
  }
  throw new Error('AI is temporarily unavailable. Please try again later.');
}

// ─── Main AI Handler ──────────────────────────────────────────────────────────
async function handleAIRequest({ sock, msg, args, botNumber, userNumber, chatId, userName, isGroup }) {
  const userInput = args.join(' ').trim();
  if (!userInput) throw new Error('Please provide a message. Usage: .gpt <your question>');

  // Load memory
  const memory = await getMemory(botNumber, userNumber, chatId);
  const historyText = memory.messages
    .map(m => `${m.role === 'user' ? 'User' : 'Assistant'}: ${m.content}`)
    .join('\n');

  const userContext = `User Name: ${userName}\nUser Number: ${userNumber}\nChat Type: ${isGroup ? 'Group' : 'Private'}`;
  const fullPrompt  = `${aiPersonalityPrompt}\n\n${userContext}\n\n${historyText ? `Conversation History:\n${historyText}\n\n` : ''}User: ${userInput}`;

  // Processing indicator
  await sock.sendMessage(chatId, { react: { text: '🧠', key: msg.key } });

  // Get voicemode settings
  const settings  = getChatSettings(botNumber, chatId);
  const vm        = settings.automation?.voicemode;
  const voiceOn   = vm?.enabled === true;
  const voiceLang = vm?.lang || 'en';

  try {
    await automationService.autoType(sock, chatId, userInput);

    // Call GPT-5
    const aiResponse       = await callGPT5(fullPrompt);
    const enhancedResponse = enhanceResponse(aiResponse);

    // Save to memory
    await appendMessage(botNumber, userNumber, chatId, 'user',      userInput);
    await appendMessage(botNumber, userNumber, chatId, 'assistant', enhancedResponse);

    // Send text reply
    await sock.sendMessage(chatId, { text: enhancedResponse }, { quoted: msg });

    // Voice note if voicemode is on
    if (voiceOn) {
      const oggBuf = await textToVoiceNote(aiResponse, voiceLang);
      if (oggBuf) {
        await sendVoiceNote(sock, chatId, oggBuf, msg);
      } else {
        await sock.sendMessage(chatId,
          { text: '⚠️ _Voice note failed — check TTS service. Text reply sent instead._' },
          { quoted: msg }
        );
      }
    }

    await sock.sendMessage(chatId, { react: { text: '✅', key: msg.key } });

  } catch (error) {
    logger.error(`[AI GPT-5] Error: ${error.message}`);
    throw new Error('AI service is currently unavailable. Please try again later.');
  }
}

